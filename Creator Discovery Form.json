        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    { \"role\": \"user\", \"content\": {{ JSON.stringify($json.gemini_prompt) }} }\n  ],\n  \"temperature\": 0.65,\n  \"max_tokens\": 1200,\n  \"response_format\": { \"type\": \"json_object\" }\n}",
