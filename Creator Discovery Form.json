    {
      "parameters": {
        "jsCode": "const d = $input.first().json.reportData;\n\nconst tierColors = {\n  \"SAFE BET\": { bg: \"#dcfce7\", text: \"#166534\", emoji: \"🛡️\" },\n  \"GROWTH BET\": { bg: \"#fef3c7\", text: \"#92400e\", emoji: \"🚀\" },\n  \"EXPERIMENTAL/VIRAL BET\": { bg: \"#fee2e2\", text: \"#991b1b\", emoji: \"⚡\" }\n};\nconst tier = tierColors[d.strategic_tier] || tierColors[\"SAFE BET\"];\nconst scoreColor = d.score >= 80 ? \"#16a34a\" : d.score >= 60 ? \"#d97706\" : \"#dc2626\";\n\nconst postsRows = (d.post_breakdown || []).map(p => `\n  <tr>\n    <td style=\"padding:8px;border-bottom:1px solid #eee;\">${p.date}</td>\n    <td style=\"padding:8px;border-bottom:1px solid #eee;\">${p.views}</td>\n    <td style=\"padding:8px;border-bottom:1px solid #eee;\">${p.likes}</td>\n    <td style=\"padding:8px;border-bottom:1px solid #eee;\">${p.comments}</td>\n    <td style=\"padding:8px;border-bottom:1px solid #eee;\">${p.performance}</td>\n  </tr>`).join(\"\");\n\nconst html = `\n<div style=\"font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;\">\n  <h2>@${d.username} <span style=\"background:${tier.bg};color:${tier.text};padding:4px 10px;border-radius:6px;font-size:14px;\">${tier.emoji} ${d.strategic_tier}</span></h2>\n  <p style=\"font-size:36px;font-weight:bold;color:${scoreColor};margin:0;\">${d.score}/100</p>\n  <p>Platform: ${d.platform} · Category: ${d.category}</p>\n  <table style=\"width:100%;text-align:center;margin:16px 0;\">\n    <tr>\n      <td><b>${d.followers}</b><br/>Followers</td>\n      <td><b>${d.avg_views}</b><br/>Avg Views</td>\n      <td><b>${d.avg_likes}</b><br/>Avg Likes</td>\n      <td><b>${d.avg_comments}</b><br/>Avg Comments</td>\n      <td><b>${d.engagement_rate}%</b><br/>Engagement</td>\n    </tr>\n  </table>\n  <p>Verified: ${d.is_verified ? \"Yes\" : \"No\"} · Engagement: ${d.engagement_verdict} · Growth: ${d.growth_signal}</p>\n  <div style=\"border-left:4px solid #5B5FEF;padding:10px 16px;background:#f5f5ff;margin:16px 0;\">${d.reasoning}</div>\n  <p><b>Best posting times:</b> ${d.timing_insight}</p>\n  <p><b>Content that works:</b> ${d.content_trend}</p>\n  <table style=\"width:100%;border-collapse:collapse;margin-top:16px;\">\n    <tr style=\"background:#f3f4f6;\">\n      <th style=\"padding:8px;text-align:left;\">Date</th>\n      <th style=\"padding:8px;text-align:left;\">Views</th>\n      <th style=\"padding:8px;text-align:left;\">Likes</th>\n      <th style=\"padding:8px;text-align:left;\">Comments</th>\n      <th style=\"padding:8px;text-align:left;\">Performance</th>\n    </tr>\n    ${postsRows}\n  </table>\n  <p style=\"margin-top:20px;\"><a href=\"${d.profile_link}\">View Profile →</a></p>\n</div>`;\n\nreturn [{ json: { ...$input.first().json, html } }];"
      },
