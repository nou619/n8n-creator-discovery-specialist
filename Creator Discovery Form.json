      "parameters": {
        "jsCode": "const raw = $input.first().json;\n\nconst inputUsername = $('On form submission').first().json.username;\nconst inputPlatform = $('On form submission').first().json.platform;\n\nlet username, platform, followers, avg_views, total_likes,\n    total_comments, post_count, is_verified, is_business,\n    profile_link, posts_for_gemini;\n\nif (raw.user && raw.user.uniqueId) {\n  // TIKTOK\n  const u = raw.user;\n  const stats = raw.stats || raw.statsV2 || {};\n  const items = raw.itemList || [];\n  username = u.uniqueId;\n  platform = \"tiktok\";\n  followers = parseInt(stats.followerCount) || 0;\n  is_verified = u.verified || false;\n  is_business = u.commerceUserInfo?.commerceUser || false;\n  profile_link = `https://www.tiktok.com/@${username}`;\n  const last10 = items.slice(0, 10);\n  post_count = last10.length || 1;\n  total_likes = last10.reduce((s,p) => s + (p.stats?.diggCount||0), 0);\n  total_comments = last10.reduce((s,p) => s + (p.stats?.commentCount||0), 0);\n  const total_views = last10.reduce((s,p) => s + (p.stats?.playCount||0), 0);\n  avg_views = Math.round(total_views / post_count);\n  posts_for_gemini = last10.map(p => ({\n    timestamp: p.createTime,\n    date: new Date(p.createTime * 1000).toISOString().split(\"T\")[0],\n    views: p.stats?.playCount || 0,\n    likes: p.stats?.diggCount || 0,\n    comments: p.stats?.commentCount || 0,\n    shares: p.stats?.shareCount || 0,\n    caption: p.desc || \"\"\n  }));\n} else if (raw.data?.user) {\n  // INSTAGRAM\n  const u = raw.data.user;\n  const edges = u.edge_owner_to_timeline_media?.edges || [];\n  username = u.username;\n  platform = \"instagram\";\n  followers = u.edge_followed_by?.count || 0;\n  is_verified = u.is_verified || false;\n  is_business = u.is_business_account || false;\n  profile_link = `https://www.instagram.com/${username}`;\n  const last10 = edges.slice(0, 10);\n  post_count = last10.length || 1;\n  total_likes = last10.reduce((s,p) => s + (p.node.edge_liked_by?.count||0), 0);\n  total_comments = last10.reduce((s,p) => s + (p.node.edge_media_to_comment?.count||0), 0);\n  const total_views = last10.reduce((s,p) => s + (p.node.video_view_count||0), 0);\n  avg_views = Math.round(total_views / post_count);\n  posts_for_gemini = last10.map(p => ({\n    timestamp: p.node.taken_at_timestamp,\n    date: new Date((p.node.taken_at_timestamp||0)*1000).toISOString().split(\"T\")[0],\n    views: p.node.video_view_count || 0,\n    likes: p.node.edge_liked_by?.count || 0,\n    comments: p.node.edge_media_to_comment?.count || 0,\n    shares: 0,\n    caption: p.node.edge_media_to_caption?.edges?.[0]?.node?.text || \"\"\n  }));\n}\n\nconst avg_likes = Math.round(total_likes / post_count);\nconst avg_comments = Math.round(total_comments / post_count);\nconst engagement_rate = followers > 0\n  ? parseFloat(((avg_likes + avg_comments) / followers * 100).toFixed(2))\n  : 0;\n\nreturn [{\n  json: {\n    username, platform, followers, avg_views,\n    avg_likes, avg_comments, engagement_rate,\n    is_verified, is_business, profile_link,\n    posts_for_gemini,\n    last_updated: new Date().toISOString()\n  }\n}];"
      },
