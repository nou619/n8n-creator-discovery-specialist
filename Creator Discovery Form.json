    {
      "parameters": {
        "jsCode": "const groqResp = $input.first().json;\nconst base = $('Build Gemini Prompt').first().json;\n\nconst raw = groqResp.choices?.[0]?.message?.content || \"{}\";\nlet ai = {};\ntry {\n  ai = JSON.parse(raw.replace(/```json|```/g, \"\").trim());\n} catch(e) {\n  ai = {\n    category: \"unknown\", strategic_tier: \"SAFE BET\", score: 0,\n    outreach_priority: \"low\", reasoning: \"AI parse failed — review manually.\",\n    timing_insight: \"N/A\", content_trend: \"N/A\",\n    engagement_verdict: \"mixed\", growth_signal: \"stable\", post_breakdown: []\n  };\n}\n\nconst sheetRow = {\n  username: base.username, platform: base.platform, followers: base.followers,\n  avg_views: base.avg_views, engagement_rate: base.engagement_rate,\n  is_verified: base.is_verified, is_business: base.is_business,\n  category: ai.category || \"unknown\",\n  strategic_tier: ai.strategic_tier || \"SAFE BET\",\n  score: ai.score || 0,\n  outreach_priority: ai.outreach_priority || \"low\",\n  contacted: \"No\",\n  profile_link: base.profile_link,\n  last_updated: base.last_updated\n};\n\nconst reportData = {\n  ...sheetRow,\n  avg_likes: base.avg_likes, avg_comments: base.avg_comments,\n  reasoning: ai.reasoning || \"\",\n  timing_insight: ai.timing_insight || \"\",\n  content_trend: ai.content_trend || \"\",\n  engagement_verdict: ai.engagement_verdict || \"mixed\",\n  growth_signal: ai.growth_signal || \"stable\",\n  post_breakdown: ai.post_breakdown || []\n};\n\nreturn [{ json: { sheetRow, reportData } }];"
      },
